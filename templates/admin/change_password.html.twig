{% extends 'base.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block title %}Canopées - Modifier mon mot de passe{% endblock %}

{% block body %}
    <div class="admin-custom-page">
        <div class="admin-custom-card">
            <div class="admin-login-header">
                <img src="{{ asset('assets/images/logo-canopees.png') }}" alt="Logo Canopées" class="admin-login-logo">
                <h1 class="admin-form-title">Modifier mon mot de passe</h1>
            </div>

            <p class="admin-form-info">
                Compte connecté :
                <strong>{{ app.user.email }}</strong>
            </p>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">
                    {{ message }}
                </div>
            {% endfor %}

            {{ form_start(form, {'attr': {'class': 'admin-login-form'}}) }}

                {{ form_row(form.currentPassword) }}
                {{ form_row(form.newPassword) }}

                <div class="button-wrapper">
                    <button type="submit" class="admin-button admin-button-secondary">
                        Modifier mon mot de passe
                    </button>

                    <a href="{{ path('admin') }}" class="admin-link">
                        Retour au back-office
                    </a>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}